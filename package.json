{
  "name": "harry-ai",
  "version": "1.0.0",
  "description": "Harry A.I.",
  "main": "main.js",
  "author": "catcherntheryangl-sketch",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.harryai.app",
    "productName": "Harry A.I.",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "index.html"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
