{
  "name": "harry-ai",
  "version": "1.0.0",
  "description": "Harry A.I. — Multi-provider AI studio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.harryai.app",
    "productName": "Harry A.I.",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "installerName": "HarryAI-Setup",
      "shortcutName": "Harry A.I.",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "index.html",
      "icon.ico"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
